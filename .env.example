# -----------------------------------------------------------------------------
# price_intelligence environment variables
# Copy this file to `.env` and fill your values.
# -----------------------------------------------------------------------------

# --- Core ---
APP_DEBUG=false
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GOOGLE_MAPS_API_KEY=

# --- Routing (OSRM-first; no Google Maps key required) ---
ROUTING_PROVIDER=osrm
OSRM_BASE_URL=https://router.project-osrm.org
OSRM_CONNECT_TIMEOUT_SECONDS=1.2
OSRM_READ_TIMEOUT_SECONDS=2.8
GOOGLE_MAPS_TIMEOUT_SECONDS=8.0

# --- MapTiler routing (optional, key-based fallback) ---
MAPTILER_API_KEY=
MAPTILER_BASE_URL=https://api.maptiler.com
MAPTILER_PROFILE=driving
MAPTILER_CONNECT_TIMEOUT_SECONDS=1.2
MAPTILER_READ_TIMEOUT_SECONDS=2.8

# --- CORS / Security ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5000,http://127.0.0.1:5000
SCRAPE_API_KEY=

# --- API guardrails ---
CACHE_TTL_SECONDS=900
CACHE_MAX_ENTRIES=64
MAX_QUERY_LENGTH=80
MAX_PAGE_FETCH=3
MAX_PRODUCTS_LIMIT=200
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_SEARCH_PER_WINDOW=30
RATE_LIMIT_SCRAPE_PER_WINDOW=3

# --- OpenStreetMap location search ---
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
LOCATION_COUNTRY_CODE=pk
LOCATION_SUGGEST_LIMIT=7

# --- Delivery / travel ---
DELIVERY_BASE_FEE=80.0
DELIVERY_PER_KM=20.0

# --- Scraper runtime ---
REQUEST_TIMEOUT=6.0
REQUEST_DELAY=0.0
SCRAPER_MAX_WORKERS=12
SCRAPER_CONNECT_TIMEOUT=2.0
SCRAPER_READ_TIMEOUT=4.0
PREWARM_PRODUCTS_CACHE=true
SCRAPE_SEED_STORES=false

# --- AI service tuning (optional) ---
# Service-specific model vars override GROQ_MODEL when explicitly set.
GROQ_SEMANTIC_MODEL=llama-3.3-70b-versatile
GROQ_CONNECT_TIMEOUT_SECONDS=1.5
GROQ_READ_TIMEOUT_SECONDS=4.0

SUGGESTION_USE_AI=true
SUGGESTION_AI_MODEL=llama-3.3-70b-versatile

PRODUCT_MATCH_USE_AI=true
PRODUCT_MATCH_AI_MODEL=llama-3.3-70b-versatile

COMPARISON_USE_AI=true
COMPARISON_AI_MODEL=llama-3.3-70b-versatile

PREDICTION_AI_REASONING=false
PREDICTION_AI_MODEL=llama-3.3-70b-versatile

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:5000
